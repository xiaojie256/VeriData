# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=veri_data

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 服务配置
PORT=3000
NODE_ENV=development

# AI服务配置
AI_SERVICE_URL=http://localhost:5000

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=100MB

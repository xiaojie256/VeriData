# ============================================
# 鉴真数据系统 - 环境变量配置示例
# ============================================
# 警告: 请勿在生产环境使用此示例值！
# 必须修改为强密码和随机密钥！
# ============================================

# 数据库配置（生产环境必须修改密码）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD_MIN_12_CHARS
DB_NAME=veri_data

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT配置（必须32字符以上随机字符串）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_32_CHAR_RANDOM_STRING_MINIMUM_LENGTH_REQUIRED
JWT_EXPIRES_IN=7d

# 服务配置
PORT=3000
NODE_ENV=development
API_VERSION=v1

# AI服务配置
AI_SERVICE_URL=http://localhost:5000

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=104857600

# CORS配置（生产环境必须设置具体域名）
# CORS_ORIGIN=https://your-domain.com
